# ============================================================
# MULTI-AGENT CODING RIG — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── OpenRouter (Free Tier LLM Gateway) ──────────────────────
# Get your free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-free-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Agent Zero ───────────────────────────────────────────────
# Internal API key for OpenClaw to communicate with Agent Zero
A0_API_KEY=local-dev-key-change-me
A0_API_URL=http://agent-zero:8080

# ── LLM Model Selection ──────────────────────────────────────
# CEO Orchestrator (OpenClaw main agent)
CEO_LLM_MODEL=mistralai/mistral-7b-instruct:free
CEO_LLM_FALLBACK=google/gemma-2-9b-it:free

# Agent Zero (the hands-on coder, delegated by backend/frontend)
A0_LLM_MODEL=deepseek/deepseek-coder-v2:free
A0_LLM_FALLBACK=qwen/qwen-2.5-coder-7b-instruct:free

# arch-director (system architect)
ARCH_LLM_MODEL=google/gemma-2-9b-it:free
ARCH_LLM_FALLBACK=meta-llama/llama-3.1-8b-instruct:free

# backend-senior (server-side implementation)
BACKEND_LLM_MODEL=deepseek/deepseek-coder-v2:free
BACKEND_LLM_FALLBACK=qwen/qwen-2.5-coder-7b-instruct:free

# frontend-lead (UI implementation)
FRONTEND_LLM_MODEL=deepseek/deepseek-coder-v2:free
FRONTEND_LLM_FALLBACK=qwen/qwen-2.5-coder-7b-instruct:free

# ux-creative (design specs, no code)
UX_LLM_MODEL=google/gemma-2-9b-it:free
UX_LLM_FALLBACK=mistralai/mistral-7b-instruct:free

# mcp-integrations (infra/tooling)
MCP_LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
MCP_LLM_FALLBACK=mistralai/mistral-7b-instruct:free

# qa-guardian (testing / quality)
QA_LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
QA_LLM_FALLBACK=google/gemma-2-9b-it:free

# docs-narrator (documentation)
DOCS_LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
DOCS_LLM_FALLBACK=google/gemma-2-9b-it:free

# ── Postgres ─────────────────────────────────────────────────
POSTGRES_USER=agentrig
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=agentrig

# ── ChromaDB ─────────────────────────────────────────────────
# No auth required for local dev, add token for production
# CHROMA_AUTH_TOKEN=your-token-here

# ── Project ──────────────────────────────────────────────────
PROJECT_NAME=my-project
WORKSPACE_DIR=/workspace/project
